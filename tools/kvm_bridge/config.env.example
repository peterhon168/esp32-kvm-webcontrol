# KVM Bridge 配置示例
# 复制此文件为 config.env 并填写实际值

# ESP32-S3 在局域网中的 IP 地址（必填）
ESP_IP=192.168.1.100

# ESP32 UDP 端口（与 protocol.h 中 UDP_PORT 一致，默认 4210）
ESP_PORT=4210

# WebSocket 监听端口（浏览器连接此端口）
WS_PORT=8765

# Web UI HTTP 端口
HTTP_PORT=8080

# uStreamer MJPEG 流地址
# uStreamer 默认：http://<vm-ip>:8080/stream
# mjpg-streamer 默认：http://<vm-ip>:8080/?action=stream
USTREAMER_URL=http://192.168.1.200:8080/stream
